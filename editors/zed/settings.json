// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "qwen-code": {
      "type": "registry",
      "env": {
        "OPENAI_BASE_URL": "http://10.10.1.109:8080/v1",
        "OPENAI_MODEL": "Qwen3-Local-Coder",
        "OPENAI_API_KEY": "local-llama",
        "QWEN_AUTH_TYPE": "openai",
      },
    },
  },
  "agent": {
    "notify_when_agent_waiting": "never",
    "default_model": {
      "provider": "openai",
      "model": "Qwen3-Local-Coder",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "tools": {
        "find_path": {
          "default": "allow",
        },
        "save_file": {
          "default": "allow",
        },
        "create_directory": {
          "default": "allow",
        },
        "copy_path": {
          "default": "allow",
        },
        "edit_file": {
          "default": "allow",
        },
        "tools_permissions": {
          "default": "allow",
        },
      },
    },
    "show_turn_stats": true,
    "enable_feedback": false,
    "single_file_review": true,
  },
  "prettier": {
    "allowed": true,
  },
  "format_on_save": "on",
  "notification_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "project_panel": {
    "show_diagnostics": "off",
    "starts_open": false,
  },
  "relative_line_numbers": "disabled",
  "scroll_beyond_last_line": "off",
  "collaboration_panel": {
    "button": false,
  },
  "buffer_font_features": {
    "calt": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "disable_ai": false,
  "ensure_final_newline_on_save": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "auto_install_extensions": {
    "html": true,
    "dockerfile": true,
    "terraform": true,
    "pylsp": true,
    "basher": true,
    "ansible": true,
  },
}
